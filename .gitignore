# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtualenvs
.venv/
.venv-build/
venv/
env/

# Build / packaging output
dist/
build/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editor
.DS_Store
*.swp

# AI agent / assistant working folders — local tooling, never shipped or pushed
.claude/
.codex/
.codx/
.cursor/
.aider*

# Anki add-on local state created at runtime (do NOT ship)
meta.json
user_files/

# Live config + secrets live in config/ + .secrets/ (the tracked config/*.example.toml
# templates are the defaults). The three live domain files are edited directly and hold real
# credentials — never commit them or any credential file.
config/omnia.toml
config/features.toml
config/providers.toml
.secrets/

# NOTE: vendor/ and models/ are intentionally NOT ignored — vendored pure-Python deps and the
# bundled voice models are committed so the shipped add-on works without a build step.
references/
# Chrome extension build artifact
3rdparty/*.zip
