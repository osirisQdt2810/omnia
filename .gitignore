# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtualenvs
.venv/
venv/
env/

# Build / packaging output
dist/
build/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editor
.DS_Store
*.swp

# AI agent / assistant working folders — local tooling, never shipped or pushed
.claude/
.codex/
.codx/
.cursor/
.aider*

# Anki add-on local state created at runtime (do NOT ship)
src/omnia/meta.json
src/omnia/user_files/

# Live config + secrets live in config/ (the *.example.toml templates are the tracked
# defaults). The three live domain files are edited directly and hold real credentials —
# never commit them or any credential file.
src/omnia/config/omnia.toml
src/omnia/config/features.toml
src/omnia/config/providers.toml
src/omnia/secrets/*
!src/omnia/secrets/README.md

# NOTE: src/omnia/vendor/ is intentionally NOT ignored — vendored pure-Python deps are
# committed so the shipped add-on works without a build step. (It's empty today.)
references/
# Chrome extension build artifact
3rdparty/*.zip
